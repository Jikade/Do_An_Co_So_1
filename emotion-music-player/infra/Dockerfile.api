FROM python:3.11-slim

WORKDIR /app

COPY services/api /app

RUN pip install --no-cache-dir \
    fastapi \
    "uvicorn[standard]" \
    sqlalchemy \
    alembic \
    psycopg2-binary \
    requests \
    "python-jose[cryptography]" \
    passlib \
    email-validator \
    pydantic-settings

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]